{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Digital First",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "ink-primary",
          "color": "#0D0D0D",
          "name": "Ink Primary"
        },
        {
          "slug": "ink-secondary",
          "color": "#1A1A1A",
          "name": "Ink Secondary"
        },
        {
          "slug": "ink-muted",
          "color": "#555555",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#999999",
          "name": "Ink Faint"
        },
        {
          "slug": "paper-white",
          "color": "#FFFFFF",
          "name": "Paper White"
        },
        {
          "slug": "paper-off-white",
          "color": "#FFFFFF",
          "name": "Paper Off White"
        },
        {
          "slug": "paper-light",
          "color": "#F4F4F4",
          "name": "Paper Light"
        },
        {
          "slug": "rule-light",
          "color": "#E0E0E0",
          "name": "Rule Light"
        },
        {
          "slug": "rule-medium",
          "color": "#C0C0C0",
          "name": "Rule Medium"
        },
        {
          "slug": "accent-red",
          "color": "#CC0000",
          "name": "Accent Red"
        },
        {
          "slug": "accent-navy",
          "color": "#0046A0",
          "name": "Accent Navy"
        },
        {
          "slug": "base-black",
          "color": "#000000",
          "name": "Base Black"
        }
      ]
    },
    "custom": {
      "colophon-light": "#FFFFFF",
      "colophon-dark": "#000000",
      "colophon-accent": "#0046A0"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--paper-white)",
      "text": "var(--wp--preset--color--ink-primary)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--base-black)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent-navy)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--base-black)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent-navy)",
          "text": "var(--wp--preset--color--paper-white)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--base-black)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-primary)"
        }
      }
    }
  }
}
