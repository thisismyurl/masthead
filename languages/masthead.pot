#. Theme Name of the theme
#: style.css
msgid "Masthead"
msgstr ""

#. Theme URI of the theme
#: style.css
msgid "https://thisismyurl.com/masthead/"
msgstr ""

#. Description of the theme
#: style.css
msgid "A modern, accessible, full-site editing newspaper theme for WordPress. Built for digital publishers who demand editorial quality — bold Playfair Display headlines, flexible multi-column layouts, zero plugin dependencies. Built to WCAG 2.2 AA guidance, Core Web Vitals optimised, pure-CSS reading-progress indicator, drop-cap support, dark mode, print-ready, and RTL-ready via CSS logical properties."
msgstr ""

#. Author of the theme
#: style.css
msgid "Christopher Ross"
msgstr ""

#. Author URI of the theme
#: style.css
msgid "https://thisismyurl.com/"
msgstr ""

